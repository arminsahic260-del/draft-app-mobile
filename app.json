{
  "expo": {
    "name": "DraftDiff",
    "slug": "draft-app-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a13"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.draftdiff.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a13"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.draftdiff.mobile",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "draftdiff",
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "9c0b4ae9-9f99-40af-a2d4-bde0d11823aa"
      },
      "router": {}
    },
    "owner": "imglobal"
  }
}
